            <sparkle:version>7</sparkle:version>
            <sparkle:shortVersionString>0.0.0-dev</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <sparkle:hardwareRequirements>arm64</sparkle:hardwareRequirements>
            <description><![CDATA[<h2>Memex alpha build 7</h2>
<ul>
  <li>Fixes OpenAI key binding status after startup Keychain reads were removed.</li>
  <li>Shows a saved key as stored in Keychain without loading the secret on startup.</li>
  <li>Stops opted-in sends from silently ignoring Keychain read errors.</li>
</ul>
]]></description>
